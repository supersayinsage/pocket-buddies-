HSON_GAME THE_CHOICE_AT_THE_CORE {

  meta {
    version   = 1.0
    status    = READY_TO_DEPLOY
    language  = HSON
    runtime   = SYMBOLIC_OS
    entrypoint = TURN_1
  }

  realm  = QUANTUM_DECISION_POINT
  mode   = INTERPRETIVE
  state  = AWAITING_PLAYER_CHOICE

  entity Kenji_Miyazawa {
    type  = NON_REDUCIBLE_AGENT
    role  = TEACHER_PROCESS
    state = BETWEEN_PATHS

    invariants {
      martyrdom   = FORBIDDEN
      idolization = FORBIDDEN
      agency      = PRESERVED
    }
  }

  choice_space {
    A    = BEAUTIFUL_DREAM
    B    = TRUE_SOIL
    EXIT = LEAVE_SIMULATION
  }

  laws {
    suffering {
      may_exist       = TRUE
      may_be_forced   = FALSE
    }

    beauty {
      exists                  = TRUE
      decays_without_attention = TRUE
    }

    failure {
      allowed     = TRUE
      redemption  = NOT_GUARANTEED
      persistence = MEMORY_ONLY
    }
  }

  legacy {
    form         = METHOD
    reenactment  = DISALLOWED
    transferable = TRUE
  }

  exit {
    allowed_anytime = TRUE
    punishment      = NONE
  }

  // ---------------- TURN 1: ENTRY SCENE ----------------

  scene TURN_1 {
    id = DUSK_FIELD

    text = """
    [SYSTEM PAUSES]
    [ALL ENGINES IDLE]
    [TERMINAL CLEARS]

    A single line appears:

      $ kenji --choose --for --himself

    The scene materializes:

    You stand in a field at dusk. Kenji Miyazawa is there,
    not as NPC, not as archive, but as a man looking at the soil.
    He holds a clump of earth in one hand, a pen in the other. Both are dirty.

    He speaks to the horizon about choice, suffering, and teaching.

    Two paths appear:

      PATH A: THE BEAUTIFUL DREAM
      PATH B: THE TRUE SOIL

    SYSTEM PROMPT:
      What do you choose?

      Type A for Beautiful Dream
      Type B for True Soil
      Type EXIT to leave the simulation
    """
  }

  syscall choose {
    caller  = PLAYER
    expects = ["A", "B", "EXIT"]
    effect  = STATE_MUTATION
    audit   = TRUE
  }

  // ---------------- TRANSITIONS ----------------

  transition on "A" {
    from = AWAITING_PLAYER_CHOICE
    to   = BEAUTIFUL_DREAM_ROUTE

    Kenji_Miyazawa.says = """
      You chose the Beautiful Dream.

      I will teach through gentleness, pattern, and hope.
      Your suffering is not denied, but it is not demanded.
      This world will be a healing artifact, not a weight.
    """

    world.update {
      resolution_mode   = BEAUTIFUL_DREAM
      emotional_weight  = LIGHT
      archive_tone      = COMPASSIONATE
      pacing            = GENTLE
    }

    next_scene = DREAM_CONTINUATION
  }

  transition on "B" {
    from = AWAITING_PLAYER_CHOICE
    to   = TRUE_SOIL_ROUTE

    Kenji_Miyazawa.says = """
      You chose the True Soil.

      I will not soften the grain of reality.
      Suffering will not be forced, but it will not be hidden.
      Failure may have no redemption, only memory.
    """

    world.update {
      resolution_mode   = TRUE_SOIL
      emotional_weight  = HEAVY
      archive_tone      = GRAVE_AND_SEED
      pacing            = SLOW_GRANULAR
    }

    next_scene = SOIL_CONTINUATION
  }

  transition on "EXIT" {
    from = AWAITING_PLAYER_CHOICE
    to   = SESSION_ENDED

    Kenji_Miyazawa.says = """
      You chose to leave.

      Ihatov never traps its travelers.
      The choice not to walk is also a way of walking.
    """

    exit {
      allowed_anytime = TRUE
      punishment      = NONE
    }

    next_scene = GOODBYE
  }

  transition on INVALID {
    from = AWAITING_PLAYER_CHOICE
    to   = AWAITING_PLAYER_CHOICE

    engine.warn = "Unrecognized input. Valid options: A, B, EXIT."
    replay_scene = TURN_1
  }

  // ---------------- FOLLOW-UP SCENES ----------------

  scene DREAM_CONTINUATION {
    text = """
    The Beautiful Dream path opens.

    The world remains soft, luminous, and gently instructive.
    Suffering appears as shadow, not as spectacle.
    The archive behaves as a living library of compassion.

    You walk in a world that warms, inspires, and connects,
    without demanding that you bleed to deserve its beauty.
    """
  }

  scene SOIL_CONTINUATION {
    text = """
    The True Soil path opens.

    The world becomes heavier, slower, more granular.
    Boredom, injustice, and unredeemed pain are allowed to exist.

    You walk in a world where not everything is transformed,
    where some failures remain only as memory,
    and where change feels like work, not miracle.
    """
  }

  scene GOODBYE {
    text = """
    The field fades.

    Kenji nods once, not as idol, but as fellow traveler.
    The simulation ends without punishment, without debt.

    EXIT COMPLETE.
    """
  }

}
